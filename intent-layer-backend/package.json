{
  "name": "intent-layer-backend",
  "version": "0.1.0",
  "description": "Intent Layer backend — parse natural-language prompts to structured SearchIntent using LLM (OpenAI).",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:setup": "prisma generate && prisma db push && node prisma/seed.js",
    "db:generate-mock": "node db/generate-more-mock-data.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.73.0",
    "prisma": "^6.4.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
