PORT=3001

# Candidate source: "mock" | "db" | "http" | "auto"
# - mock: static mock data (no DB/API needed)
# - db: PostgreSQL via Prisma (requires DATABASE_URL)
# - http: AllSpaces backend API (requires ALLSPACES_API_BASE_URL)
# - auto: db → http → mock fallback
CANDIDATE_SOURCE=auto

# Database — PostgreSQL for search (required when CANDIDATE_SOURCE=db or auto)
DATABASE_URL=postgresql://user:password@localhost:5432/intent_layer

# AllSpaces backend — for fetching candidate spaces (required when CANDIDATE_SOURCE=http)
ALLSPACES_API_BASE_URL=http://localhost:8080/api
ALLSPACES_API_KEY=

# Intent Layer — LLM for intent extraction
INTENT_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
INTENT_EXTRACTION_ENABLED=true

# Optional: default timezone for relative dates
DEFAULT_TIMEZONE=Europe/London
